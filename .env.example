# Server Environment Variables
# Copy this file to server/.env and fill in your values

# SMTP Configuration (required for email verification)
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_auth_code

# Server Port
PORT=3001

# CORS Allowed Origins (comma-separated, leave empty for development)
ALLOWED_ORIGINS=

# App URL (for password reset links)
APP_URL=http://localhost:5173

# Deploy Configuration (for deploy.mjs)
DEPLOY_HOST=
DEPLOY_PORT=22
DEPLOY_USER=
DEPLOY_PASS=
# DEPLOY_KEY_PATH=~/.ssh/id_rsa
# DEPLOY_REMOTE_APP=/var/www/html/flashcard
# DEPLOY_REMOTE_API=/opt/flashcard-api
